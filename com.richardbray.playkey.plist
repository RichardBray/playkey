<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.richardbray.playkey</string>

    <!-- Edit this path if your playkey binary lives elsewhere. -->
    <key>ProgramArguments</key>
    <array>
        <string>/Users/robray/playkey/playkey</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/playkey.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/playkey.err</string>
</dict>
</plist>
